{
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(pnpm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git pull *)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh run *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(date *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(jq *)",
      "Bash(curl -X POST *)",
      "Edit(/app/**)",
      "Edit(/components/**)",
      "Edit(/lib/**)",
      "Edit(/tests/**)",
      "Edit(/supabase/**)",
      "Edit(.claude/sprint-state.md)",
      "Edit(.claude/sprint-log.md)",
      "Edit(.claude/rules/**)",
      "Edit(.claude/agents/**)",
      "Edit(.claude/hooks/**)",
      "Edit(CLAUDE.md)",
      "Edit(docs/**)",
      "Write(/app/**)",
      "Write(/components/**)",
      "Write(/lib/**)",
      "Write(/tests/**)",
      "Write(.claude/sprint-state.md)",
      "Write(.claude/sprint-log.md)",
      "Write(docs/**)"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(rm -rf *)",
      "Bash(wget *)",
      "Bash(chmod 777 *)",
      "Bash(sudo *)",
      "Read(.env*)",
      "Read(**/*.pem)",
      "Read(**/*secret*)",
      "Read(**/*credential*)",
      "Edit(.env*)",
      "Edit(/.github/workflows/**)",
      "Edit(package-lock.json)"
    ]
  },
  "attribution": {
    "commit": "Co-authored-by: AI Sprint Team",
    "pr": ""
  },
  "env": {
    "MAX_MCP_OUTPUT_TOKENS": "50000"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session/on-start.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-tool/block-dangerous.sh",
            "statusMessage": "セキュリティチェック中..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-tool/auto-quality.sh",
            "timeout": 60,
            "statusMessage": "品質チェック中..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-tool/update-progress.sh",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/subagent/on-stop.sh",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session/on-stop.sh",
            "async": true
          }
        ]
      }
    ]
  }
}
